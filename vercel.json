{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "VITE_DB_USER": "postgres",
    "VITE_DB_HOST": "postgres-host.vercel-storage.com",
    "VITE_DB_NAME": "ComandeJa_SaaS",
    "VITE_DB_PASSWORD": "vercel-postgres-password",
    "VITE_DB_PORT": "5432"
  }
} 