{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "rewrites": [
    { "source": "/(assets/.+)", "destination": "/$1" },
    { "source": "/api/(.*)", "destination": "/server.cjs" },
    { "source": "/(.*)", "destination": "/server.cjs" }
  ],
  "builds": [
    { "src": "server.cjs", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" }}
  ],
  "env": {
    "VITE_DB_USER": "postgres",
    "VITE_DB_HOST": "postgres-host.vercel-storage.com",
    "VITE_DB_NAME": "ComandeJa_SaaS",
    "VITE_DB_PASSWORD": "vercel-postgres-password",
    "VITE_DB_PORT": "5432",
    "NODE_ENV": "production"
  }
} 