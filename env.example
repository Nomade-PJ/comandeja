# Variáveis de ambiente para desenvolvimento local
# Para produção na Vercel, configure estas mesmas variáveis no dashboard da Vercel

# Configurações do Supabase
VITE_SUPABASE_URL=sua_url_supabase
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_supabase

# Ambiente (development, production)
NODE_ENV=development

# Porta da aplicação
PORT=3000

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Chave para JWT (temporária)
JWT_SECRET=chave_secreta_forte_32_caracteres_minimo 